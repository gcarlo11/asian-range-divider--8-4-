//@version=6
indicator("Asia Range Divider [8 Levels]", overlay=true,
          max_lines_count=500, max_labels_count=400, max_boxes_count=20)

//  I N P U T S
var string G_SESS = "📅 Asia Session"
i_sess_time = input.string("0700-1500", "Session Time (GMT+7)",
              group=G_SESS, tooltip="Format: HHMM-HHMM  |  Default = 07:00–15:00 GMT+7")
i_show_lvls = input.bool(true, "Show Levels",      group=G_SESS)
i_show_box  = input.bool(true, "Show Session Box", group=G_SESS)

var string G_FILT = "⚙️ Confirmation Filters"
i_use_vol  = input.bool(true,  "Volume Filter",              group=G_FILT)
i_vol_len  = input.int(20,     "Volume MA Length",            group=G_FILT, minval=1)
i_use_atr  = input.bool(true,  "ATR Filter",                 group=G_FILT)
i_atr_len  = input.int(14,     "ATR Length",                 group=G_FILT, minval=1)
i_atr_thr  = input.float(0.0,  "ATR Min Threshold (0=auto)", group=G_FILT, minval=0,
              step=0.00001, tooltip="0 = half of 50-bar ATR SMA (auto-adaptive)")
i_use_rsi  = input.bool(true, "RSI Filter",  group=G_FILT)
i_rsi_len  = input.int(14,    "RSI Length",  group=G_FILT, minval=1)

var string G_VIS = "🎨 Visuals"
i_debug    = input.bool(false, "Debug Mode (Info Table)", group=G_VIS)

//  S E S S I O N   D E T E C T I O N   (UTC+7)
bool in_asia    = not na(time(timeframe.period, i_sess_time, "UTC+7"))
bool asia_start = in_asia     and not in_asia[1]   // rising edge
bool asia_end   = not in_asia and     in_asia[1]   // falling edge

// ── Store UNIX-millisecond timestamps for every drawing ───────────────────────
// These are wall-clock anchors — unaffected by bar_index, zoom, or TF.
var int t_open  = na     // time of the first bar inside the session
var int t_close = na     // time of the last  bar inside the session

if asia_start
    t_open := time

// asia_end fires on the FIRST bar after the session; time[1] = last session bar
if asia_end
    t_close := time[1]

// ── One bar width in ms (used to size the box right-edge flush to bar) ────────
int bar_ms = timeframe.in_seconds() * 1000

//  S E S S I O N   H I G H  /  L O W   (live)
var float sess_hi = na
var float sess_lo = na

if asia_start
    sess_hi := high
    sess_lo := low
else if in_asia
    sess_hi := math.max(sess_hi, high)
    sess_lo := math.min(sess_lo, low)

//  L O C K E D   L E V E L S   (9 prices, set once when session closes)
var float lk_hi = na
var float lk_lo = na

var float lv0 = na
var float lv1 = na
var float lv2 = na
var float lv3 = na
var float lv4 = na
var float lv5 = na
var float lv6 = na
var float lv7 = na
var float lv8 = na

if asia_end
    lk_hi := sess_hi
    lk_lo := sess_lo
    float step = (lk_hi - lk_lo) / 8.0
    lv0 := lk_lo
    lv1 := lk_lo + step
    lv2 := lk_lo + step * 2
    lv3 := lk_lo + step * 3
    lv4 := lk_lo + step * 4
    lv5 := lk_lo + step * 5
    lv6 := lk_lo + step * 6
    lv7 := lk_lo + step * 7
    lv8 := lk_hi

// ── Helpers ───────────────────────────────────────────────────────────────────
f_get_lvl(int idx) =>
    switch idx
        0 => lv0
        1 => lv1
        2 => lv2
        3 => lv3
        4 => lv4
        5 => lv5
        6 => lv6
        7 => lv7
        8 => lv8
        => float(na)

f_lvl_color(int idx) =>
    idx >= 6 ? color.new(#FF4444, 0) :
     idx <= 2 ? color.new(#00CC66, 0) :
     color.new(#AAAAAA, 40)

//  S E S S I O N   B O X   — anchored to t_open / t_close (bar_time)
// KEY: xloc.bar_time means left/right are Unix ms → immune to bar_index shifts
var box asia_box = na

if i_show_box
    if asia_start
        box.delete(asia_box)
        // right = time + bar_ms so the box covers the full width of the first bar
        asia_box := box.new(
             left         = t_open,
             top          = sess_hi,
             right        = time + bar_ms,
             bottom       = sess_lo,
             xloc         = xloc.bar_time,
             border_color = color.new(#FF9800, 30),
             bgcolor      = color.new(#FF9800, 88),
             border_width = 1)

    if in_asia and not na(asia_box)
        // Stretch the box rightward to the current bar's right edge
        box.set_right(asia_box, time + bar_ms)
        box.set_top(asia_box, sess_hi)
        box.set_bottom(asia_box, sess_lo)

//  D R A W   L E V E L   L I N E S   &   L A B E L S
//  • Lines: xloc.bar_time + extend.right → pinned to session-close wall time,
//           extend infinitely rightward. Never shifts on zoom / TF change.
//  • Labels: created with xloc.bar_time, then x is updated to current bar's
//            time every bar so they always float at the chart's right edge.
var line[]  lvl_lines  = array.new_line()
var label[] lvl_labels = array.new_label()

if asia_end and i_show_lvls
    // Purge previous session drawings
    for ln in lvl_lines
        line.delete(ln)
    array.clear(lvl_lines)

    for lb in lvl_labels
        label.delete(lb)
    array.clear(lvl_labels)

    // t_close = last bar of session; draw from there, extend right forever
    for i = 0 to 8
        float  lvl         = f_get_lvl(i)
        color  c           = f_lvl_color(i)
        bool   is_boundary = (i == 0 or i == 8)

        string zone_tag = i >= 6 ? " ▲ Supply" : i <= 2 ? " ▼ Demand" : " ● Mid"
        string lbl_text = i == 0 ? "L0 — Asia Low"  + zone_tag :
                           i == 8 ? "L8 — Asia High" + zone_tag :
                           "L" + str.tostring(i) + zone_tag

        // ── Horizontal level line ─────────────────────────────────────────────
        // x1/x2 are Unix-ms timestamps (xloc.bar_time).
        // extend.right makes the line stretch to the right edge of ANY zoom level.
        line ln = line.new(
             x1     = t_close,
             y1     = lvl,
             x2     = t_close + bar_ms,
             y2     = lvl,
             xloc   = xloc.bar_time,
             color  = c,
             width  = is_boundary ? 2 : 1,
             style  = is_boundary ? line.style_solid : line.style_dashed,
             extend = extend.right)
        array.push(lvl_lines, ln)

        // ── Label — xloc.bar_time; x is floated to right edge every bar ───────
        label lb = label.new(
             x         = t_close,
             y         = lvl,
             text      = lbl_text,
             xloc      = xloc.bar_time,
             color     = color.new(c, 75),
             textcolor = c,
             style     = label.style_label_left,
             size      = size.small)
        array.push(lvl_labels, lb)

// ── Float labels to the live right edge of the chart ─────────────────────────
// label.set_x() with xloc.bar_time accepts a Unix-ms value.
// Setting x = time on every bar means the label is always at the newest candle.
// This is zoom-proof because it uses wall-clock time, not bar_index.
if i_show_lvls and array.size(lvl_labels) > 0
    for lb in lvl_labels
        label.set_x(lb, time)

//  I N D I C A T O R   C A L C U L A T I O N S
float rsi_val  = ta.rsi(close, i_rsi_len)
float atr_val  = ta.atr(i_atr_len)
float vol_ma   = ta.sma(volume, i_vol_len)
float atr_auto = ta.sma(atr_val, 50) * 0.5
float atr_thr  = i_atr_thr > 0.0 ? i_atr_thr : atr_auto

//  C O N F I R M A T I O N   F I L T E R S
bool vol_ok    = not i_use_vol or (volume > vol_ma)
bool atr_ok    = not i_use_atr or (atr_val > atr_thr)
bool rsi_long  = not i_use_rsi or (rsi_val > 50)
bool rsi_short = not i_use_rsi or (rsi_val < 50)

bool confirm_long  = vol_ok and atr_ok and rsi_long
bool confirm_short = vol_ok and atr_ok and rsi_short

//  S I G N A L   L O G I C   (post-session only)
bool  post_session = not in_asia and not na(lk_hi)

bool  buy_sig     = false
bool  sell_sig    = false
float buy_target  = na
float sell_target = na

if post_session
    for i = 0 to 8
        float lvl = f_get_lvl(i)
        if not na(lvl)
            bool cross_up = close > lvl and close[1] <= lvl
            bool cross_dn = close < lvl and close[1] >= lvl

            if cross_up and confirm_long and not buy_sig
                buy_sig    := true
                buy_target := i < 8 ? f_get_lvl(i + 1) : na

            if cross_dn and confirm_short and not sell_sig
                sell_sig    := true
                sell_target := i > 0 ? f_get_lvl(i - 1) : na

//  V I S U A L   O U T P U T
plotshape(buy_sig,  title="Buy Signal",  location=location.belowbar,
          color=color.lime, style=shape.triangleup,   size=size.normal)
plotshape(sell_sig, title="Sell Signal", location=location.abovebar,
          color=color.red,  style=shape.triangledown, size=size.normal)

// ── TP labels pinned to the SIGNAL BAR's wall time ───────────────────────────
// xloc.bar_time + x=time → permanently anchored to that candle's timestamp,
// immune to future zooming, scrolling, or timeframe changes.
if buy_sig and not na(buy_target)
    label.new(
         x         = time,
         y         = buy_target,
         text      = "🎯 TP " + str.tostring(buy_target, format.mintick),
         xloc      = xloc.bar_time,
         color     = color.new(color.green, 70),
         textcolor = color.lime,
         style     = label.style_label_down,
         size      = size.small)

if sell_sig and not na(sell_target)
    label.new(
         x         = time,
         y         = sell_target,
         text      = "🎯 TP " + str.tostring(sell_target, format.mintick),
         xloc      = xloc.bar_time,
         color     = color.new(color.red, 70),
         textcolor = color.red,
         style     = label.style_label_up,
         size      = size.small)

//  A L E R T S
alertcondition(buy_sig,  title="BUY Signal",
               message="BUY signal: Level Break with Confirmation — {{ticker}} {{interval}}")
alertcondition(sell_sig, title="SELL Signal",
               message="SELL signal: Level Break with Confirmation — {{ticker}} {{interval}}")

//  D E B U G   T A B L E
var table dbg = table.new(position.top_right, 2, 9,
                          bgcolor      = color.new(color.black, 65),
                          border_color = color.new(color.gray, 40),
                          border_width = 1)

if barstate.islast and i_debug
    table.cell(dbg, 0, 0, "📊 Debug Info",
               text_color=color.yellow, text_size=size.small, bgcolor=color.new(#1A237E,40))
    table.cell(dbg, 1, 0, "Value",
               text_color=color.yellow, text_size=size.small, bgcolor=color.new(#1A237E,40))

    table.cell(dbg, 0, 1, "Asia High", text_color=color.red,  text_size=size.small)
    table.cell(dbg, 1, 1, str.tostring(lk_hi, format.mintick), text_color=color.red,  text_size=size.small)

    table.cell(dbg, 0, 2, "Asia Low",  text_color=color.lime, text_size=size.small)
    table.cell(dbg, 1, 2, str.tostring(lk_lo, format.mintick), text_color=color.lime, text_size=size.small)

    float rng = not na(lk_hi) ? lk_hi - lk_lo : na
    table.cell(dbg, 0, 3, "Range",      text_color=color.white, text_size=size.small)
    table.cell(dbg, 1, 3, str.tostring(rng, format.mintick),    text_color=color.white, text_size=size.small)

    color rsi_c = rsi_val > 50 ? color.lime : color.red
    table.cell(dbg, 0, 4, "RSI(" + str.tostring(i_rsi_len) + ")", text_color=color.white, text_size=size.small)
    table.cell(dbg, 1, 4, str.tostring(math.round(rsi_val, 2)) + (rsi_val > 50 ? " ▲" : " ▼"),
               text_color=rsi_c, text_size=size.small)

    color atr_c = atr_val > atr_thr ? color.lime : color.red
    table.cell(dbg, 0, 5, "ATR(" + str.tostring(i_atr_len) + ")", text_color=color.white, text_size=size.small)
    table.cell(dbg, 1, 5, str.tostring(atr_val, format.mintick),   text_color=atr_c,       text_size=size.small)

    float vol_pct = vol_ma > 0 ? math.round(volume / vol_ma * 100) : 0
    color vol_c   = volume > vol_ma ? color.lime : color.red
    table.cell(dbg, 0, 6, "Vol / MA%",           text_color=color.white, text_size=size.small)
    table.cell(dbg, 1, 6, str.tostring(vol_pct) + "%", text_color=vol_c, text_size=size.small)

    table.cell(dbg, 0, 7, "Long Filters",  text_color=color.white, text_size=size.small)
    table.cell(dbg, 1, 7, confirm_long  ? "✅ PASS" : "❌ FAIL",
               text_color=confirm_long  ? color.lime : color.red, text_size=size.small)

    table.cell(dbg, 0, 8, "Short Filters", text_color=color.white, text_size=size.small)
    table.cell(dbg, 1, 8, confirm_short ? "✅ PASS" : "❌ FAIL",
               text_color=confirm_short ? color.lime : color.red, text_size=size.small)

//  END OF SCRIPT
