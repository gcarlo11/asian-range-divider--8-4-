// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  ASIA RANGE DIVIDER  v6 — Breakout + Bounce Dual-Mode Engine               ║
// ║  Pine Script v6  ·  Dynamic Risk:Reward Enforcer                           ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

//@version=6
strategy("Asia Range Divider [8+4] v6 Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, max_lines_count=500, max_labels_count=500, max_boxes_count=50)

//  I N P U T S
var string G_SESS   = "📅 Asia Session"
string i_sess_time  = input.string("0700-1500", "Session Time (GMT+7)",        group=G_SESS)
bool   i_show_lvls  = input.bool(true,  "Show Range Levels",                   group=G_SESS)
bool   i_show_ext   = input.bool(true,  "Show Extension Levels",               group=G_SESS)
bool   i_show_box   = input.bool(true,  "Show Session Box",                    group=G_SESS)
bool   i_show_hist  = input.bool(false, "Show Past Session History",           group=G_SESS)

var string G_KF     = "🔬 Kalman Filter"
float  i_kf_q       = input.float(0.01, "Process Noise Q (lower = smoother)",  group=G_KF, minval=0.0001, maxval=1.0, step=0.001)
float  i_kf_r       = input.float(1.0,  "Measurement Noise R (higher = smoother)", group=G_KF, minval=0.1, maxval=10.0, step=0.1)

var string G_SIG    = "⚙️ Signal Engine"
bool   i_brk_on     = input.bool(true,  "Enable Breakout Signals",             group=G_SIG)
bool   i_bnc_on     = input.bool(true,  "Enable Bounce / Reversal Signals",    group=G_SIG)
int    i_brk_score  = input.int(3, "Breakout — min score (0–5)",               group=G_SIG, minval=0, maxval=5)
int    i_bnc_score  = input.int(3, "Bounce — min score (0–5)",                 group=G_SIG, minval=0, maxval=5)
int    i_adx_len    = input.int(14,   "ADX Length",                            group=G_SIG, minval=1)
float  i_adx_thr    = input.float(20.0, "ADX Trend Threshold",                 group=G_SIG, minval=5.0, step=1.0)
float  i_body_ratio = input.float(0.45, "Min Body Ratio for breakout (0–1)",   group=G_SIG, minval=0.1, maxval=0.99, step=0.05)
float  i_wick_ratio = input.float(0.35, "Min Wick Ratio for bounce (0–1)",     group=G_SIG, minval=0.1, maxval=0.99, step=0.05)
int    i_vol_len    = input.int(20,   "Volume MA Length",                      group=G_SIG, minval=2)
float  i_vol_z      = input.float(0.8, "Volume Z-Score Threshold",             group=G_SIG, minval=0.1, step=0.1)
float  i_pb_tol     = input.float(0.25, "Breakout pullback tolerance (× step)",group=G_SIG, minval=0.0, maxval=0.5, step=0.05)

var string G_TRADE  = "🎯 Trade Management"
float  i_rr         = input.float(1.0, "Risk:Reward Ratio Target",             group=G_TRADE, minval=0.5, step=0.1)
bool   i_use_grid_tp= input.bool(false, "Use strict grid levels for TP",       group=G_TRADE)
bool   i_lock_trade = input.bool(true, "Lock: no new signal until TP or SL",   group=G_TRADE)
bool   i_reset_sess = input.bool(true, "Reset trade lock on new session",      group=G_TRADE)

var string G_VIS    = "🎨 Visuals"
bool   i_show_kf    = input.bool(true,  "Show Kalman Filter line",             group=G_VIS)
bool   i_show_score = input.bool(true,  "Show score on signal label",          group=G_VIS)
bool   i_debug      = input.bool(false, "Debug Table",                         group=G_VIS)

//  S E S S I O N   D E T E C T I O N
bool   in_asia    = not na(time(timeframe.period, i_sess_time, "UTC+7"))
bool   asia_start = in_asia     and not in_asia[1]
bool   asia_end   = not in_asia and     in_asia[1]

var int t_open  = na
var int t_close = na
var int t_end   = na

if asia_start
    t_open := time
if asia_end
    t_close := time[1]
    t_end   := int(t_close / 86400000) * 86400000 + 72000000

int bar_ms = timeframe.in_seconds() * 1000

//  S E S S I O N   H I G H / L O W
var float sess_hi = na
var float sess_lo = na

if asia_start
    sess_hi := high
    sess_lo := low
else if in_asia
    sess_hi := math.max(sess_hi, high)
    sess_lo := math.min(sess_lo, low)

//  L O C K E D   L E V E L S
var float lk_hi = na
var float lk_lo = na
var float lk_step = na

var float lv0 = na
var float lv1 = na
var float lv2 = na
var float lv3 = na
var float lv4 = na
var float lv5 = na
var float lv6 = na
var float lv7 = na
var float lv8 = na

var float ex_dn1 = na
var float ex_dn2 = na
var float ex_dn3 = na
var float ex_dn4 = na
var float ex_up1 = na
var float ex_up2 = na
var float ex_up3 = na
var float ex_up4 = na

if asia_end
    lk_hi   := sess_hi
    lk_lo   := sess_lo
    lk_step := (lk_hi - lk_lo) / 8.0
    float s  = lk_step
    
    lv0 := lk_lo
    lv1 := lk_lo + s
    lv2 := lk_lo + s*2
    lv3 := lk_lo + s*3
    lv4 := lk_lo + s*4
    lv5 := lk_lo + s*5
    lv6 := lk_lo + s*6
    lv7 := lk_lo + s*7
    lv8 := lk_hi
    
    ex_dn1 := lk_lo - s
    ex_dn2 := lk_lo - s*2
    ex_dn3 := lk_lo - s*3
    ex_dn4 := lk_lo - s*4
    
    ex_up1 := lk_hi + s
    ex_up2 := lk_hi + s*2
    ex_up3 := lk_hi + s*3
    ex_up4 := lk_hi + s*4

f_flat_lvl(int fi) =>
    switch fi
        0  => ex_dn4
        1  => ex_dn3
        2  => ex_dn2
        3  => ex_dn1
        4  => lv0
        5  => lv1
        6  => lv2
        7  => lv3
        8  => lv4
        9  => lv5
        10 => lv6
        11 => lv7
        12 => lv8
        13 => ex_up1
        14 => ex_up2
        15 => ex_up3
        16 => ex_up4
        => float(na)

f_flat_color(int fi) =>
    fi >= 13 ? color.new(#880000, 0) : fi >= 10 ? color.new(#FF4444, 0) : fi >= 7  ? color.new(#AAAAAA, 40) : fi >= 4  ? color.new(#00CC66, 0) : color.new(#004400, 0)

//  K A L M A N   F I L T E R
var float kf_price = close
var float kf_vel   = 0.0
var float kf_p     = 1.0

float kf_p_pred = kf_p + i_kf_q
float kf_x_pred = kf_price + kf_vel
float kf_k      = kf_p_pred / (kf_p_pred + i_kf_r)
float kf_innov  = close - kf_x_pred
kf_price := kf_x_pred + kf_k * kf_innov
kf_vel   := kf_vel    + kf_k * kf_innov
kf_p     := (1.0 - kf_k) * kf_p_pred

bool kf_rising  = kf_vel > 0 and kf_vel >= kf_vel[1]
bool kf_falling = kf_vel < 0 and kf_vel <= kf_vel[1]
bool kf_was_rising  = kf_vel[1] > 0 and kf_vel[1] >= kf_vel[2]
bool kf_was_falling = kf_vel[1] < 0 and kf_vel[1] <= kf_vel[2]
bool kf_accel_up   = kf_vel > kf_vel[1] and kf_vel[1] > kf_vel[2]
bool kf_accel_down = kf_vel < kf_vel[1] and kf_vel[1] < kf_vel[2]

//  A D X  &  V O L U M E
[_dip, _dim, adx_val] = ta.dmi(i_adx_len, i_adx_len)
bool is_trending = adx_val > i_adx_thr
bool is_ranging  = not is_trending

float vol_mean = ta.sma(volume,  i_vol_len)
float vol_std  = ta.stdev(volume, i_vol_len)
float vol_z_prev = vol_std > 0 ? (volume[1] - vol_mean) / vol_std : 0.0

float rng_prev  = high[1] - low[1]
float body_prev = math.abs(close[1] - open[1])
bool body_ok_prev = rng_prev > 0 and (body_prev / rng_prev) >= i_body_ratio

float low_wick_prev  = math.min(close[1], open[1]) - low[1]
float high_wick_prev = high[1] - math.max(close[1], open[1])
bool  lo_wick_ok     = rng_prev > 0 and (low_wick_prev  / rng_prev) >= i_wick_ratio
bool  hi_wick_ok     = rng_prev > 0 and (high_wick_prev / rng_prev) >= i_wick_ratio

//  S E S S I O N   B O X  &  L I N E S
var box asia_box = na
if i_show_box
    if asia_start
        box.delete(asia_box)
        asia_box := box.new(left=t_open, top=sess_hi, right=time+bar_ms, bottom=sess_lo, xloc=xloc.bar_time, border_color=color.new(#FF9800,30), bgcolor=color.new(#FF9800,88), border_width=1)
    if in_asia and not na(asia_box)
        box.set_right(asia_box, time+bar_ms)
        box.set_top(asia_box, sess_hi)
        box.set_bottom(asia_box, sess_lo)

var line[]  all_lines    = array.new_line()
var label[] all_labels   = array.new_label()
var label[] float_labels = array.new_label()

if asia_end
    if not i_show_hist
        for ln in all_lines
            line.delete(ln)
        array.clear(all_lines)
        for lb in all_labels
            label.delete(lb)
        array.clear(all_labels)
    array.clear(float_labels)

    for fi = 0 to 16
        bool is_range = fi >= 4 and fi <= 12
        bool is_ext   = not is_range
        if (is_range and not i_show_lvls) or (is_ext and not i_show_ext)
            continue
            
        float lvl    = f_flat_lvl(fi)
        color c      = f_flat_color(fi)
        bool  is_key = (fi==0 or fi==4 or fi==12 or fi==16)

        line ln = line.new(x1=t_close, y1=lvl, x2=t_end, y2=lvl, xloc=xloc.bar_time, color=c, width=is_key?2:1, style=is_ext?line.style_dotted:is_key?line.style_solid:line.style_dashed)
        array.push(all_lines, ln)

//  T R A D E   S T A T E
var bool  in_trade   = false
var bool  trade_long = false
var float trade_tp   = na
var float trade_sl   = na
var line  tp_ln      = na
var line  sl_ln      = na

if asia_start and i_reset_sess
    in_trade := false
    strategy.close_all(comment="Session Close")

bool tp_hit = false
bool sl_hit = false

if in_trade
    tp_hit := trade_long ? high >= trade_tp : low  <= trade_tp
    sl_hit := trade_long ? low  <= trade_sl : high >= trade_sl

    if tp_hit or sl_hit
        in_trade := false
        if not na(tp_ln)
            line.set_x2(tp_ln, time)
        if not na(sl_ln)
            line.set_x2(sl_ln, time)

//  S I G N A L   S C A N
bool post_session = not in_asia and not na(lk_hi)
bool can_enter    = not i_lock_trade or not in_trade

bool brk_buy = false
bool brk_sell = false
bool bnc_buy = false
bool bnc_sell = false
float sig_tp = na
float sig_sl = na
int sig_score = 0
bool sig_is_bounce = false

if post_session and can_enter
    // ── BREAKOUT BUY ─────────────────────────────────────────────────────────
    if i_brk_on and not brk_buy
        for fi = 0 to 16
            float lvl = f_flat_lvl(fi)
            if not na(lvl) and not na(lk_step)
                if close[1] > lvl and close[2] <= lvl and close > lvl and low >= (lvl - lk_step * i_pb_tol)
                    int sc = (kf_was_rising?1:0) + (adx_val[1]>i_adx_thr?1:0) + (open[1]<lvl?1:0) + (body_ok_prev?1:0) + (vol_z_prev>=i_vol_z?1:0)
                    if sc >= i_brk_score
                        float sl_c = fi > 0 ? f_flat_lvl(fi-1) : float(na)
                        float grid_tp = fi < 16 ? f_flat_lvl(fi+1) : float(na)
                        float tp_c = i_use_grid_tp ? grid_tp : (close + (close - sl_c) * i_rr)
                        if not na(tp_c) and not na(sl_c)
                            brk_buy := true
                            sig_tp := tp_c
                            sig_sl := sl_c
                            sig_score := sc
                            break

    // ── BREAKOUT SELL ────────────────────────────────────────────────────────
    if i_brk_on and not brk_buy and not brk_sell
        for fi = 16 to 0
            float lvl = f_flat_lvl(fi)
            if not na(lvl) and not na(lk_step)
                if close[1] < lvl and close[2] >= lvl and close < lvl and high <= (lvl + lk_step * i_pb_tol)
                    int sc = (kf_was_falling?1:0) + (adx_val[1]>i_adx_thr?1:0) + (open[1]>lvl?1:0) + (body_ok_prev?1:0) + (vol_z_prev>=i_vol_z?1:0)
                    if sc >= i_brk_score
                        float sl_c = fi < 16 ? f_flat_lvl(fi+1) : float(na)
                        float grid_tp = fi > 0 ? f_flat_lvl(fi-1) : float(na)
                        float tp_c = i_use_grid_tp ? grid_tp : (close - (sl_c - close) * i_rr)
                        if not na(tp_c) and not na(sl_c)
                            brk_sell := true
                            sig_tp := tp_c
                            sig_sl := sl_c
                            sig_score := sc
                            break

    // ── BOUNCE BUY ───────────────────────────────────────────────────────────
    if i_bnc_on and not brk_buy and not brk_sell and not bnc_buy
        for fi = 0 to 16
            float lvl = f_flat_lvl(fi)
            if not na(lvl) and not na(lk_step)
                float tol = lk_step * 0.15    
                if low[1] <= lvl + tol and close[1] > lvl and close[1] > open[1] and close > close[1] and close > open
                    bool is_key = (fi==0 or fi==4 or fi==12 or fi==16)
                    int sc = (kf_accel_up?1:0) + ((is_ranging or is_key)?1:0) + (lo_wick_ok?1:0) + (close[1]>lvl+tol?1:0) + (vol_z_prev>=i_vol_z*0.5?1:0)
                    if sc >= i_bnc_score
                        float sl_c = fi > 0 ? f_flat_lvl(fi-1) : float(na)
                        float grid_tp = fi < 16 ? f_flat_lvl(fi+1) : float(na)
                        float tp_c = i_use_grid_tp ? grid_tp : (close + (close - sl_c) * i_rr)
                        if not na(tp_c) and not na(sl_c)
                            bnc_buy := true
                            sig_tp := tp_c
                            sig_sl := sl_c
                            sig_score := sc
                            sig_is_bounce := true
                            break

    // ── BOUNCE SELL ──────────────────────────────────────────────────────────
    if i_bnc_on and not brk_buy and not brk_sell and not bnc_buy and not bnc_sell
        for fi = 16 to 0 
            float lvl = f_flat_lvl(fi)
            if not na(lvl) and not na(lk_step)
                float tol = lk_step * 0.15
                if high[1] >= lvl - tol and close[1] < lvl and close[1] < open[1] and close < close[1] and close < open
                    bool is_key = (fi==0 or fi==4 or fi==12 or fi==16)
                    int sc = (kf_accel_down?1:0) + ((is_ranging or is_key)?1:0) + (hi_wick_ok?1:0) + (close[1]<lvl-tol?1:0) + (vol_z_prev>=i_vol_z*0.5?1:0)
                    if sc >= i_bnc_score
                        float sl_c = fi < 16 ? f_flat_lvl(fi+1) : float(na)
                        float grid_tp = fi > 0 ? f_flat_lvl(fi-1) : float(na)
                        float tp_c = i_use_grid_tp ? grid_tp : (close - (sl_c - close) * i_rr)
                        if not na(tp_c) and not na(sl_c)
                            bnc_sell := true
                            sig_tp := tp_c
                            sig_sl := sl_c
                            sig_score := sc
                            sig_is_bounce := true
                            break

bool buy_sig  = brk_buy  or bnc_buy
bool sell_sig = brk_sell or bnc_sell

// ── Execute Trade ────────────────────────────────────────────────────────────
if buy_sig or sell_sig
    in_trade   := true
    trade_long := buy_sig
    trade_tp   := sig_tp
    trade_sl   := sig_sl
    
    if buy_sig
        strategy.entry("Long", strategy.long)
        strategy.exit("TP/SL Long", "Long", limit=trade_tp, stop=trade_sl)
    if sell_sig
        strategy.entry("Short", strategy.short)
        strategy.exit("TP/SL Short", "Short", limit=trade_tp, stop=trade_sl)

    line.delete(tp_ln)
    line.delete(sl_ln)
    int le = not na(t_end) ? t_end : time + bar_ms * 300
    tp_ln := line.new(x1=time, y1=sig_tp, x2=le, y2=sig_tp, xloc=xloc.bar_time, color=color.new(color.lime,35), style=line.style_dashed, width=1)
    sl_ln := line.new(x1=time, y1=sig_sl, x2=le, y2=sig_sl, xloc=xloc.bar_time, color=color.new(color.red,35),  style=line.style_dashed, width=1)

    if i_show_score
        string mode_tag = sig_is_bounce ? " 🔄 BOUNCE" : " ⚡ BREAKOUT"
        string display_text = (buy_sig ? "🟢 BUY" : "🔴 SELL") + mode_tag + "\nTP → " + str.tostring(sig_tp, format.mintick) + "\nSL → " + str.tostring(sig_sl, format.mintick) + "\nRR " + str.tostring(i_rr) + ":1 Target"
        label.new(x=time, y=buy_sig ? low : high, text=display_text, xloc=xloc.bar_time, color=buy_sig ? color.new(#003300,55) : color.new(#330000,55), textcolor=buy_sig ? color.lime : color.red, style=buy_sig ? label.style_label_upper_right : label.style_label_lower_right, size=size.small)

//  P L O T S
plot(i_show_kf ? kf_price : na, "Kalman Filter", color = kf_vel > 0 ? color.new(#00AAFF,50) : color.new(#FF6600,50), linewidth = 1)
plotshape(brk_buy,  title="BUY Breakout",  location=location.belowbar, color=color.lime,  style=shape.triangleup,   size=size.normal)
plotshape(brk_sell, title="SELL Breakout", location=location.abovebar, color=color.red,   style=shape.triangledown, size=size.normal)
plotshape(bnc_buy,  title="BUY Bounce",    location=location.belowbar, color=color.new(#00FFCC,0), style=shape.circle, size=size.small)
plotshape(bnc_sell, title="SELL Bounce",   location=location.abovebar, color=color.new(#FF88AA,0), style=shape.circle, size=size.small)
bgcolor(is_ranging ? color.new(color.gray, 97) : na, title="Ranging Market Tint")